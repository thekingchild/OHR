{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "serve (static, no install)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "-l", "3000", "."],
      "port": 3000
    },
    {
      "name": "vercel dev (honours vercel.json)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "vercel", "dev", "--listen", "3001"],
      "port": 3001
    },
    {
      "name": "python http.server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
